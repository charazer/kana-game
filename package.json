        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/svelte": "5.4.2",
        "@types/node": "25.9.5",
        "@typescript-eslint/eslint-plugin": "8.63.0",
        "@typescript-eslint/parser": "8.63.0",
        "@vitest/coverage-v8": "4.1.10",
