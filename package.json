{
    "name": "kana-game",
    "version": "0.1.0",
    "private": false,
    "type": "module",
    "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
    "engines": {
        "node": ">=25.0.0"
    },
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "test": "pnpm run test:unit:coverage && pnpm run test:e2e",
        "test:unit": "vitest run",
        "test:unit:ui": "vitest --ui",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "@sveltejs/vite-plugin-svelte": "7.1.2",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/svelte": "5.3.1",
        "@types/node": "25.9.3",
        "@typescript-eslint/eslint-plugin": "8.61.1",
        "@typescript-eslint/parser": "8.61.1",
        "@vitest/coverage-v8": "4.1.9",
        "@vitest/ui": "4.1.9",
        "eslint": "10.4.1",
        "eslint-config-prettier": "10.1.8",
        "happy-dom": "20.10.1",
        "svelte": "5.56.3",
        "typescript": "6.0.3",
        "typescript-eslint": "8.61.1",
        "vite": "8.0.16",
        "vitest": "4.1.9"
    }
}
